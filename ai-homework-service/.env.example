NODE_ENV=development
PORT=8080
CORS_ALLOWED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173,http://127.0.0.1:5188,http://localhost:5188,https://iman-bakhruz.vercel.app,https://your-project.vercel.app

REDIS_URL=redis://127.0.0.1:6379
REDIS_PREFIX=aihw

CACHE_TTL_SECONDS=86400

RATE_LIMIT_PER_MINUTE=8
RATE_LIMIT_PER_DAY=220

QUEUE_CONCURRENCY=1
QUEUE_INTERVAL_CAP=8
QUEUE_INTERVAL_MS=60000
QUEUE_TASK_TIMEOUT_MS=60000

AI_REQUEST_TIMEOUT_MS=30000
AI_RETRY_ATTEMPTS=2
AI_RETRY_BACKOFF_MS=600

MAX_IMAGE_BYTES=6291456

# For socket-only deploy you can leave this empty.
# For AI + socket deploy set one or more providers, for example: gemini
PROVIDER_ORDER=gemini

# Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# DeepSeek
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com

# OpenRouter
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_SITE_URL=http://localhost:8080
OPENROUTER_APP_NAME=AI Homework Service
